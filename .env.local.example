# ==============================================================================
# OMWIS 환경변수 템플릿 — 실제 키 채워 .env.local 로 복사
# (.env.local 은 .gitignore 에 의해 자동 제외됨)
# ==============================================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# --- 카카오 알림톡 (알리고 Aligo, 4개 모두 채워야 실발송 / 하나라도 비면 Mock) ---
KAKAO_API_KEY=        # 알리고 apikey
KAKAO_USER_ID=        # 알리고 계정 ID
KAKAO_SENDER_KEY=     # 발신프로필 키(senderkey)
KAKAO_SENDER=         # 등록된 발신 번호 (예: 0312345678)

# --- 이메일 (Resend, 미보유 시 빈 값 → Mock 모드) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@hongi.co.kr

# --- 세금계산서: 공급자(자사) 사업자정보 (실발행 전 필수) ---
SUPPLIER_BIZ_NUMBER=   # 000-00-00000
SUPPLIER_NAME=(주)홍지
SUPPLIER_CEO=변지수
SUPPLIER_ADDRESS=
SUPPLIER_BIZ_TYPE=제조
SUPPLIER_BIZ_ITEM=알루미늄
SUPPLIER_EMAIL=tax@hongi.co.kr

# --- 세금계산서: 팝빌(Popbill) 발행 (미설정 시 Mock) ---
POPBILL_LINK_ID=
POPBILL_SECRET=

# --- ACIS 연동 ---
ACIS_API_URL=https://your-acis.vercel.app

# --- 사업자등록번호 진위확인 (국세청 공공데이터포털) ---
# 신청: https://data.go.kr → "국세청_사업자등록정보 진위확인 및 상태조회"
# 빈 값이면 형식 검증(체크섬)만 수행 — Mock 모드
BIZ_VERIFY_API_KEY=

# --- 앱 URL ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Vercel Cron (주간 회장 리포트 보호) ---
# Vercel 프로젝트 Settings → Environment Variables 에 동일 값 등록
# Cron 요청은 자동으로 Authorization: Bearer ${CRON_SECRET} 헤더로 전송됨
CRON_SECRET=change-me-to-random-long-string
